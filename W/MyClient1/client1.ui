   <string notr="true">/* 全局背景与字体 */
QWidget#Client1 {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #eef2f7, stop:1 #e2e8f0);
    font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;, &quot;PingFang SC&quot;, Roboto, Arial;
    font-size: 13px;
}

/* ----- 按钮通用样式 ----- */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #5c9ce6, stop:1 #4a86c8);
    border: none;
    border-radius: 6px;
    color: white;
    font-weight: bold;
    padding: 8px 16px;
    min-height: 20px;
}
QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #6aacef, stop:1 #5c96e0);
}
QPushButton:pressed {
    background: #3d73b3;
}

/* 断开连接按钮（独立配色） */
QPushButton#pushButton_2 {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #e6895e, stop:1 #d9774a);
}
QPushButton#pushButton_2:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #f0996b, stop:1 #e58757);
}
QPushButton#pushButton_2:pressed {
    background: #c2653a;
}

/* 发送按钮（绿色主题） */
QPushButton#pushButton_3 {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #4caf50, stop:1 #43a047);
    border-radius: 5px;
    padding: 6px 20px;
}
QPushButton#pushButton_3:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #5ecf62, stop:1 #55b955);
}
QPushButton#pushButton_3:pressed {
    background: #2e7d32;
}

/* 输入框 + 文本编辑区 */
QLineEdit, QTextEdit {
    border: 1px solid #cfdde6;
    border-radius: 6px;
    background-color: #ffffff;
    padding: 5px 8px;
    selection-background-color: #5c9ce6;
    font-size: 12px;
}
QLineEdit:focus, QTextEdit:focus {
    border: 1px solid #5c9ce6;
    outline: none;
}
QTextEdit {
    padding: 6px;
}

/* QGroupBox 卡片样式 */
QGroupBox {
    border: 1px solid #cfdfeb;
    border-radius: 12px;
    margin-top: 12px;
    background-color: rgba(255, 255, 255, 0.85);
    font-weight: bold;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 16px;
    padding: 0 8px;
    background-color: transparent;
    color: #2c3e50;
    font-size: 13px;
    font-weight: 600;
}

/* 美化滚动条（适用于 QTextEdit） */
QScrollBar:vertical {
    width: 10px;
    background: #f0f3f8;
    border-radius: 5px;
    margin: 0px;
}
QScrollBar::handle:vertical {
    background: #b9c8e5;
    border-radius: 5px;
    min-height: 25px;
}
QScrollBar::handle:vertical:hover {
    background: #8fb0d4;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}</string>
